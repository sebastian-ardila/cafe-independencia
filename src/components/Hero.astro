---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  compact?: boolean;
  backgroundImage?: string;
}

const { title, subtitle, ctaText, ctaHref, secondaryCtaText, secondaryCtaHref, compact = false, backgroundImage } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const bgUrl = backgroundImage ? `${base}${backgroundImage}` : undefined;
---

<section class:list={['hero', { compact }]}>
  <div class="hero-bg">
    {bgUrl && <img src={bgUrl} alt="" class="hero-bg-img" />}
    <div class="hero-overlay"></div>
    <div class="hero-glow"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-pill animate-in">
      <span class="pill-dot"></span>
      Pereira, Colombia
    </div>
    <h1 class="animate-in delay-1">{title}</h1>
    <p class="animate-in delay-2">{subtitle}</p>
    {(ctaText || secondaryCtaText) && (
      <div class="hero-actions animate-in delay-3">
        {ctaText && ctaHref && <a href={ctaHref} class="btn btn-primary btn-lg">{ctaText}</a>}
        {secondaryCtaText && secondaryCtaHref && <a href={secondaryCtaHref} class="btn btn-ghost">{secondaryCtaText}</a>}
      </div>
    )}
  </div>
  {!compact && (
    <div class="hero-chevron">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  )}
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero.compact { min-height: 40vh; }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: var(--color-bg-dark);
  }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8,8,8,0.65) 0%, rgba(8,8,8,0.8) 100%);
  }

  .hero-glow {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-secondary), transparent);
    opacity: 0.4;
  }

  .hero-content {
    position: relative;
    text-align: center;
    z-index: 1;
    max-width: 820px;
    padding: 2rem 0;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-accent);
    background: rgba(212, 162, 78, 0.08);
    border: 1px solid rgba(212, 162, 78, 0.15);
    padding: 0.55rem 1.5rem;
    border-radius: var(--radius-full);
    margin-bottom: 2.5rem;
  }

  .pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-secondary);
    box-shadow: 0 0 10px var(--color-secondary);
    animation: pulse 2s ease-in-out infinite;
  }

  .compact .hero-pill { margin-bottom: 1.5rem; }

  .hero-content h1 {
    font-size: clamp(3rem, 8vw, 5.5rem);
    color: var(--color-white);
    letter-spacing: -0.04em;
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .hero-content p {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.45);
    max-width: 480px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-chevron {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: var(--color-secondary);
    animation: chevronBounce 2s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .hero { min-height: 90dvh; }
    .hero.compact { min-height: 35vh; }
    .hero-content p { font-size: 1rem; }
  }
</style>
