---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
  compact?: boolean;
}

const { title, subtitle, ctaText, ctaHref, compact = false } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<section class:list={['hero', { compact }]}>
  <div class="hero-bg">
    <div class="hero-mesh"></div>
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-glow"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-pill animate-in">
      <span class="pill-dot"></span>
      Pereira, Colombia
    </div>
    <h1 class="animate-in delay-1">{title}</h1>
    <p class="animate-in delay-2">{subtitle}</p>
    {ctaText && ctaHref && (
      <div class="hero-actions animate-in delay-3">
        <a href={ctaHref} class="btn btn-primary btn-lg">{ctaText}</a>
      </div>
    )}
  </div>
  {!compact && (
    <div class="hero-scroll-indicator">
      <div class="scroll-mouse">
        <div class="scroll-wheel"></div>
      </div>
    </div>
  )}
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero.compact {
    min-height: 40vh;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: #0a0908;
  }

  .hero-mesh {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(at 40% 20%, rgba(200, 150, 90, 0.06) 0px, transparent 50%),
      radial-gradient(at 80% 0%, rgba(200, 150, 90, 0.04) 0px, transparent 50%),
      radial-gradient(at 0% 50%, rgba(200, 150, 90, 0.03) 0px, transparent 50%);
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .hero-orb-1 {
    width: 500px;
    height: 500px;
    background: rgba(200, 150, 90, 0.12);
    top: -15%;
    right: -5%;
    animation: float 10s ease-in-out infinite;
  }

  .hero-orb-2 {
    width: 350px;
    height: 350px;
    background: rgba(176, 125, 58, 0.08);
    bottom: -10%;
    left: -5%;
    animation: float 14s ease-in-out infinite reverse;
  }

  .hero-glow {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-secondary), transparent);
    opacity: 0.3;
  }

  .hero-content {
    position: relative;
    text-align: center;
    z-index: 1;
    max-width: 760px;
    padding: 2rem 0;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-accent);
    background: rgba(200, 150, 90, 0.06);
    border: 1px solid rgba(200, 150, 90, 0.12);
    padding: 0.55rem 1.5rem;
    border-radius: var(--radius-full);
    margin-bottom: 2.5rem;
  }

  .pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-secondary);
    box-shadow: 0 0 8px var(--color-secondary);
    animation: pulse 2s ease-in-out infinite;
  }

  .compact .hero-pill { margin-bottom: 1.5rem; }

  .hero-content h1 {
    font-size: 4.5rem;
    color: var(--color-bg);
    letter-spacing: -0.04em;
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #fefefe 0%, rgba(254, 254, 254, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .compact .hero-content h1 { font-size: 3rem; }

  .hero-content p {
    font-size: 1.1rem;
    color: rgba(254, 254, 254, 0.4);
    max-width: 460px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }

  .btn-lg {
    padding: 1.1rem 2.5rem;
    font-size: 0.95rem;
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  .scroll-mouse {
    width: 22px;
    height: 34px;
    border: 2px solid rgba(200, 150, 90, 0.25);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-wheel {
    width: 3px;
    height: 8px;
    background: var(--color-secondary);
    border-radius: 3px;
    animation: float 1.5s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .hero { min-height: 90dvh; }
    .hero.compact { min-height: 35vh; }
    .hero-content h1 { font-size: 2.75rem; }
    .compact .hero-content h1 { font-size: 2rem; }
    .hero-content p { font-size: 1rem; }
    .hero-orb-1 { width: 250px; height: 250px; }
    .hero-orb-2 { width: 180px; height: 180px; }
  }
</style>
