---
interface Variant {
  id: string;
  label: string;
  price: number;
}

interface Props {
  id: string;
  name: string;
  description: string;
  image: string;
  popular?: boolean;
  variants: Variant[];
}

const { id, name, description, image, popular, variants } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const formatPrice = (price: number) => '$' + price.toLocaleString('es-CO');
---

<div class="product-card" data-product-id={id} data-product-name={name} data-variants={JSON.stringify(variants)}>
  {popular && <div class="popular-badge">Mas vendido</div>}
  <div class="product-img-wrap">
    <img src={`${base}${image}`} alt={name} loading="lazy" />
  </div>
  <div class="product-body">
    <div class="product-info">
      <h3>{name}</h3>
      <p class="product-desc">{description}</p>
    </div>
    <div class="product-actions">
      <div class="variant-selector">
        {variants.map((v, i) => (
          <button
            class:list={['chip', 'variant-chip', { active: i === 0 }]}
            data-variant-id={v.id}
            data-price={v.price}
            data-label={v.label}
          >
            {v.label}
          </button>
        ))}
      </div>
      <div class="product-bottom">
        <div class="product-price" data-price-display>{formatPrice(variants[0].price)}</div>
        <div class="quantity-control">
          <button class="qty-btn qty-minus" aria-label="Reducir cantidad">&minus;</button>
          <span class="qty-value">0</span>
          <button class="qty-btn qty-plus" aria-label="Aumentar cantidad">+</button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .product-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: all var(--transition);
    overflow: hidden;
    height: 100%;
  }

  .product-card:hover {
    border-color: rgba(212, 162, 78, 0.15);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .product-card.selected {
    border-color: var(--color-secondary);
    box-shadow: var(--shadow-glow);
  }

  .popular-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-full);
    z-index: 2;
  }

  .product-img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-warm);
    flex-shrink: 0;
  }

  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover .product-img-wrap img {
    transform: scale(1.05);
  }

  .product-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-info {
  }

  .product-info h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    letter-spacing: -0.02em;
  }

  .product-desc {
    font-size: 0.88rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .product-actions {
    margin-top: auto;
    padding-top: 1.25rem;
  }

  .variant-selector {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .product-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .product-price {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-primary);
    letter-spacing: -0.02em;
  }

  .quantity-control {
    display: flex;
    align-items: center;
    background: var(--color-bg);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .qty-btn {
    width: 38px;
    height: 38px;
    border: none;
    background: transparent;
    cursor: pointer;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-light);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
    font-family: var(--font-body);
  }

  .qty-btn:hover {
    background: var(--color-accent-light);
    color: var(--color-secondary);
  }

  .qty-btn:active { transform: scale(0.92); }

  .qty-value {
    min-width: 32px;
    text-align: center;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }
</style>
