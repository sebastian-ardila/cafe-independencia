---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Contacto" description="Visítanos en Pereira o pedí por WhatsApp. Horarios, ubicación y formas de contacto.">
  <Hero
    title="Contacto"
    subtitle="Estamos en el centro de Pereira o pedí directo por WhatsApp"
    compact
  />

  <section class="section">
    <div class="container">
      <div class="contact-layout">
        <div class="info-cards">
          <div class="info-card">
            <div class="info-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div class="info-content">
              <span class="info-label">Dirección</span>
              <h3>Cra 7 # 19-32, Centro</h3>
              <p>Pereira, Risaralda — Colombia</p>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div class="info-content">
              <span class="info-label">Horario</span>
              <div class="hours">
                <div class="hours-row">
                  <span>Lunes a Viernes</span>
                  <span class="hours-time">7:00 — 20:00</span>
                </div>
                <div class="hours-row">
                  <span>Sábados</span>
                  <span class="hours-time">8:00 — 21:00</span>
                </div>
                <div class="hours-row">
                  <span>Domingos</span>
                  <span class="hours-time">9:00 — 18:00</span>
                </div>
              </div>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg></div>
            <div class="info-content">
              <span class="info-label">Contacto</span>
              <p>WhatsApp: +57 302 323 1629</p>
              <p>hola@cafeindependencia.co</p>
            </div>
          </div>

          <a href="https://wa.me/573023231629?text=¡Hola!%20Quiero%20más%20información%20sobre%20Café%20Independencia" target="_blank" rel="noopener" class="info-card info-card-wa">
            <div class="wa-content">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <div>
                <span class="wa-title">Escríbenos por WhatsApp</span>
                <span class="wa-sub">Respuesta inmediata</span>
              </div>
            </div>
            <span class="wa-arrow">&rarr;</span>
          </a>
        </div>

        <div class="map-card">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.5!2d-75.69!3d4.81!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNMKwNDgnMzYuMCJOIDc1wrA0MScyNC4wIlc!5e0!3m2!1ses!2sco!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Café Independencia en Pereira"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="or-divider">
    <div class="container">
      <div class="or-line">
        <span>o</span>
      </div>
    </div>
  </div>

  <!-- Form Section -->
  <section class="section form-section">
    <div class="container">
      <div class="form-wrapper">
        <div class="form-header">
          <h2>Dejanos tus datos</h2>
          <p>Te contactaremos tan pronto como sea posible.</p>
        </div>
        <form id="contact-form" class="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Nombre</label>
              <input type="text" id="name" name="name" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <label for="phone">Telefono</label>
              <input type="tel" id="phone" name="phone" placeholder="Tu numero de telefono" required />
            </div>
          </div>
          <div class="form-group">
            <label for="message">Mensaje</label>
            <textarea id="message" name="message" rows="4" placeholder="En que podemos ayudarte?"></textarea>
          </div>
          <button type="submit" class="btn btn-whatsapp form-submit">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 1.5rem;
    align-items: start;
  }

  .info-cards {
    display: grid;
    gap: 1rem;
  }

  .info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    gap: 1.25rem;
    transition: all var(--transition);
  }

  .info-card:hover {
    border-color: rgba(200, 150, 90, 0.15);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .info-card-wa {
    background: var(--color-whatsapp);
    border-color: transparent;
    color: var(--color-white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    padding: 1.25rem 1.5rem;
  }

  .info-card-wa:hover {
    background: #20c05c;
    border-color: transparent;
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(37, 211, 102, 0.3);
  }

  .wa-content {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .wa-title {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .wa-sub {
    display: block;
    font-size: 0.8rem;
    opacity: 0.8;
  }

  .wa-arrow {
    font-size: 1.5rem;
    font-weight: 300;
  }

  .info-icon {
    font-size: 1.3rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-light);
    border-radius: 14px;
    flex-shrink: 0;
  }

  .info-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-secondary);
    margin-bottom: 0.4rem;
  }

  .info-content h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
  }

  .info-content p {
    color: var(--color-text-light);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .hours {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    color: var(--color-text-light);
    gap: 1rem;
  }

  .hours-time {
    font-weight: 600;
    color: var(--color-text);
  }

  .map-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
    min-height: 100%;
  }

  .map-card iframe {
    min-height: 540px;
  }

  /* Or Divider */
  .or-divider {
    padding: 0;
  }

  .or-line {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .or-line::before,
  .or-line::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .or-line span {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: lowercase;
  }

  /* Form Section */
  .form-section {
    padding: 4rem 0 6rem;
    background: var(--color-bg-warm);
  }

  .form-wrapper {
    max-width: 640px;
    margin: 0 auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 3rem;
  }

  .form-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .form-header h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .form-header p {
    font-size: 0.95rem;
    color: var(--color-text-light);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-text);
    background: var(--color-bg);
    transition: all var(--transition-fast);
    outline: none;
    resize: vertical;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-muted);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-secondary);
    box-shadow: 0 0 0 3px rgba(200, 150, 90, 0.1);
  }

  .form-submit {
    width: 100%;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .form-wrapper {
      padding: 2rem 1.5rem;
    }
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .map-card iframe {
      min-height: 350px;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const name = (form.querySelector('#name') as HTMLInputElement).value.trim();
      const phone = (form.querySelector('#phone') as HTMLInputElement).value.trim();
      const message = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();

      let text = `Hola, soy ${name}.\n`;
      if (phone) text += `Mi telefono: ${phone}\n`;
      if (message) text += `\n${message}`;

      const encoded = encodeURIComponent(text);
      window.open(`https://wa.me/573023231629?text=${encoded}`, '_blank');
    });
  }
</script>
