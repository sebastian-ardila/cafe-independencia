---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import ServiceCard from '../components/ServiceCard.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const products = [
  {
    id: 'cafe-empacado',
    name: 'Cafe Empacado',
    description: 'Cafe de origen del eje cafetero. Disponible molido y en grano. Tostion artesanal semanal con notas de panela, chocolate y frutas.',
    image: 'producto-cafe.jpg',
    popular: true,
    variants: [
      { id: 'cafe-250', label: '250g', price: 25000 },
      { id: 'cafe-454', label: '454g', price: 45000 },
      { id: 'cafe-2500', label: '2.5kg', price: 220000 },
    ],
  },
  {
    id: 'cold-brew',
    name: 'Cold Brew',
    description: 'Extraccion en frio por 18 horas. Suave, dulce y refrescante. Listo para tomar en botella de vidrio.',
    image: 'producto-cold-brew.jpg',
    variants: [
      { id: 'cb-240', label: '240ml', price: 8000 },
      { id: 'cb-500', label: '500ml', price: 15000 },
      { id: 'cb-750', label: 'Institucional 750ml', price: 22000 },
    ],
  },
  {
    id: 'metodos',
    name: 'Metodos de Preparacion',
    description: 'Filtros y accesorios para preparar cafe de especialidad en casa. Equipo profesional seleccionado.',
    image: 'v60-coffee.jpg',
    variants: [
      { id: 'prensa', label: 'Prensa Francesa', price: 65000 },
      { id: 'v60', label: 'V60', price: 45000 },
      { id: 'chemex', label: 'Chemex', price: 120000 },
    ],
  },
];

const services = [
  {
    name: 'Taller de Barista',
    description: 'Aprende tecnicas de extraccion, latte art y cata de cafe con nuestros baristas certificados. Sesiones grupales e individuales.',
    whatsappMessage: 'Hola! Estoy interesado en el Taller de Barista. Me pueden dar mas informacion?',
  },
  {
    name: 'Barra de Cafe para Eventos',
    description: 'Montamos una barra de cafe de especialidad para tu evento social. Bodas, cumpleanos, reuniones y celebraciones.',
    whatsappMessage: 'Hola! Quiero cotizar una barra de cafe para un evento social. Me pueden dar mas informacion?',
  },
  {
    name: 'Eventos y Ferias Empresariales',
    description: 'Acompanamiento profesional en ferias, conferencias y eventos corporativos con servicio de cafe de especialidad.',
    whatsappMessage: 'Hola! Estoy interesado en el servicio de cafe para eventos/ferias empresariales. Me pueden dar mas informacion?',
  },
];
---

<Layout title="Inicio">
  <Hero
    title="Cafe de especialidad del eje cafetero"
    subtitle="Tostion artesanal semanal con granos de fincas de Risaralda. Pide directo y te lo llevamos."
    ctaText="Ver productos"
    ctaHref="#productos"
    secondaryCtaText="Nuestros servicios"
    secondaryCtaHref="#servicios"
    backgroundImage="v60-coffee.jpg"
  />

  <!-- Features Strip -->
  <section class="features">
    <div class="container">
      <div class="features-grid">
        <div class="feature-card">
          <span class="feature-num">01</span>
          <h3>Origen Directo</h3>
          <p>De fincas del eje cafetero a tu mesa. Risaralda, Quindio y Caldas.</p>
        </div>
        <div class="feature-card">
          <span class="feature-num">02</span>
          <h3>Tostion Semanal</h3>
          <p>Tostamos en pequenos lotes cada semana para maxima frescura.</p>
        </div>
        <div class="feature-card">
          <span class="feature-num">03</span>
          <h3>Envio a Colombia</h3>
          <p>Arma tu pedido y te lo enviamos. Pago contra entrega o transferencia.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="section" id="productos">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Nuestro cafe</span>
        <h2 class="section-title">Productos</h2>
        <p class="section-subtitle">Tostado artesanal del eje cafetero, listo para pedir por WhatsApp.</p>
      </div>
      <div class="products-grid">
        {products.map((p) => <ProductCard {...p} />)}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section-dark" id="servicios">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Experiencias</span>
        <h2 class="section-title">Servicios</h2>
        <p class="section-subtitle">Mas alla del cafe empacado, llevamos la experiencia a tu evento.</p>
      </div>
      <div class="services-grid">
        {services.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-glow-top"></div>
    <div class="container cta-inner">
      <span class="section-label" style="color: var(--color-accent)">Pereira, Colombia</span>
      <h2>Listo para probar el mejor cafe de la region?</h2>
      <p>Arma tu pedido arriba o consultanos por un servicio para tu evento.</p>
      <div class="cta-actions">
        <a href="#productos" class="btn btn-primary btn-lg">Ver productos</a>
        <a href={`${base}contacto`} class="btn btn-ghost">Contacto</a>
      </div>
    </div>
  </section>

  <!-- Floating Cart -->
  <div class="cart-float" id="cart-float">
    <div class="cart-summary">
      <div class="cart-info">
        <div class="cart-icon-wrap">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <span class="cart-badge" id="cart-badge">0</span>
        </div>
        <div class="cart-details">
          <span class="cart-items-text" id="cart-items-text">Tu pedido</span>
          <span class="cart-total" id="cart-total">$0</span>
        </div>
      </div>
      <button class="btn btn-whatsapp cart-checkout" id="cart-checkout">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir por WhatsApp
      </button>
    </div>
    <div class="cart-items-list" id="cart-items-list"></div>
  </div>
</Layout>

<style is:global>
  /* Features Strip */
  .features {
    padding: 0;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .feature-card {
    padding: 3rem 2.5rem;
    border-right: 1px solid var(--color-border);
    transition: all var(--transition);
  }

  .feature-card:last-child { border-right: none; }
  .feature-card:hover { background: var(--color-accent-light); }

  .feature-num {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 800;
    color: var(--color-secondary);
    line-height: 1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.04em;
  }

  .feature-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .feature-card p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.65;
  }

  /* Section header */
  .section-header { text-align: center; }

  /* Products */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Services */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* CTA */
  .cta-section {
    position: relative;
    background: var(--color-primary);
    padding: 7rem 0;
    overflow: hidden;
    text-align: center;
  }

  .cta-glow-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-secondary), transparent);
    opacity: 0.4;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 580px;
  }

  .cta-inner .section-label::before { background: var(--color-accent); }

  .cta-inner h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--color-white);
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .cta-inner p {
    color: rgba(255, 255, 255, 0.4);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Floating Cart */
  .cart-float {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(120%);
    z-index: 90;
    width: calc(100% - 3rem);
    max-width: 560px;
    background: var(--color-primary);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl), 0 0 0 1px rgba(255, 255, 255, 0.05);
    padding: 1.25rem 1.5rem;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .cart-float.visible { transform: translateX(-50%) translateY(0); }

  .cart-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cart-info { display: flex; align-items: center; gap: 0.85rem; }

  .cart-icon-wrap {
    position: relative;
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    color: var(--color-white);
  }

  .cart-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 20px;
    height: 20px;
    background: var(--color-whatsapp);
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-badge.bump { animation: pulse 0.3s ease; }
  .cart-details { display: flex; flex-direction: column; }
  .cart-items-text { font-size: 0.78rem; color: rgba(255,255,255,0.45); font-weight: 500; }
  .cart-total { font-family: var(--font-heading); font-size: 1.2rem; font-weight: 700; color: var(--color-white); }

  .cart-checkout {
    padding: 0.75rem 1.5rem;
    font-size: 0.82rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .cart-items-list {
    display: none;
    padding-top: 1rem;
    margin-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    flex-direction: column;
    gap: 0.5rem;
  }

  .cart-items-list.show { display: flex; }

  .cart-item-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .cart-item-qty { color: var(--color-accent); font-weight: 600; }

  @media (max-width: 1024px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
    .services-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .features-grid { grid-template-columns: 1fr; }
    .feature-card { border-right: none; border-bottom: 1px solid var(--color-border); padding: 2rem; }
    .feature-card:last-child { border-bottom: none; }
    .products-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
    .services-grid { grid-template-columns: 1fr; }
    .cart-float { bottom: 1rem; width: calc(100% - 2rem); padding: 1rem 1.25rem; border-radius: var(--radius-lg); }
    .cart-summary { flex-wrap: wrap; }
    .cart-checkout { width: 100%; margin-top: 0.5rem; }
    .cta-inner h2 { font-size: 2rem; }
  }
</style>

<script>
  const WHATSAPP_NUMBER = '573023231629';

  interface CartItem {
    productName: string;
    variantLabel: string;
    price: number;
    qty: number;
  }

  const cart: Record<string, CartItem> = {};

  function updateGlobalUI() {
    const items = Object.values(cart);
    const totalItems = items.reduce((s, i) => s + i.qty, 0);
    const totalPrice = items.reduce((s, i) => s + i.qty * i.price, 0);

    const badge = document.getElementById('cart-badge');
    if (badge) {
      badge.textContent = String(totalItems);
      badge.classList.remove('bump');
      void badge.offsetWidth;
      badge.classList.add('bump');
    }

    const totalEl = document.getElementById('cart-total');
    if (totalEl) totalEl.textContent = '$' + totalPrice.toLocaleString('es-CO');

    const itemsText = document.getElementById('cart-items-text');
    if (itemsText) {
      itemsText.textContent = totalItems === 0 ? 'Tu pedido' : totalItems === 1 ? '1 producto' : totalItems + ' productos';
    }

    const cartFloat = document.getElementById('cart-float');
    if (cartFloat) cartFloat.classList.toggle('visible', totalItems > 0);

    const listEl = document.getElementById('cart-items-list');
    if (listEl) {
      listEl.innerHTML = '';
      listEl.classList.toggle('show', totalItems > 0);
      for (const item of Object.values(cart)) {
        if (item.qty > 0) {
          const row = document.createElement('div');
          row.className = 'cart-item-row';
          row.innerHTML = `<span>${item.productName} (${item.variantLabel})</span><span class="cart-item-qty">${item.qty}x $${(item.price * item.qty).toLocaleString('es-CO')}</span>`;
          listEl.appendChild(row);
        }
      }
    }

    document.querySelectorAll('.product-card').forEach(card => {
      const variants = JSON.parse(card.getAttribute('data-variants') || '[]');
      const hasItems = variants.some((v: any) => cart[v.id] && cart[v.id].qty > 0);
      card.classList.toggle('selected', hasItems);
    });
  }

  document.querySelectorAll('.product-card').forEach(card => {
    const productName = card.getAttribute('data-product-name') || '';
    const variants = JSON.parse(card.getAttribute('data-variants') || '[]');
    const chips = card.querySelectorAll('.variant-chip');
    const priceDisplay = card.querySelector('[data-price-display]');
    const qtyEl = card.querySelector('.qty-value');
    const plusBtn = card.querySelector('.qty-plus');
    const minusBtn = card.querySelector('.qty-minus');

    if (!qtyEl || !plusBtn || !minusBtn || variants.length === 0) return;

    let selectedVariantId = variants[0].id;

    function getSelectedVariant() {
      return variants.find((v: any) => v.id === selectedVariantId);
    }

    function updateQtyDisplay() {
      const item = cart[selectedVariantId];
      qtyEl!.textContent = String(item ? item.qty : 0);
    }

    chips.forEach((chip: Element) => {
      chip.addEventListener('click', () => {
        chips.forEach((c: Element) => c.classList.remove('active'));
        chip.classList.add('active');

        selectedVariantId = chip.getAttribute('data-variant-id') || '';
        const price = parseInt(chip.getAttribute('data-price') || '0');

        if (priceDisplay) {
          priceDisplay.textContent = '$' + price.toLocaleString('es-CO');
        }

        updateQtyDisplay();
      });
    });

    plusBtn.addEventListener('click', () => {
      const v = getSelectedVariant();
      if (!v) return;

      if (!cart[selectedVariantId]) {
        const activeChip = card.querySelector('.variant-chip.active');
        cart[selectedVariantId] = {
          productName,
          variantLabel: activeChip?.getAttribute('data-label') || v.label,
          price: v.price,
          qty: 0,
        };
      }
      cart[selectedVariantId].qty++;
      updateQtyDisplay();
      updateGlobalUI();
    });

    minusBtn.addEventListener('click', () => {
      if (!cart[selectedVariantId] || cart[selectedVariantId].qty <= 0) return;
      cart[selectedVariantId].qty--;
      if (cart[selectedVariantId].qty === 0) delete cart[selectedVariantId];
      updateQtyDisplay();
      updateGlobalUI();
    });
  });

  const checkoutBtn = document.getElementById('cart-checkout');
  if (checkoutBtn) {
    checkoutBtn.addEventListener('click', () => {
      const items = Object.values(cart).filter(i => i.qty > 0);
      if (items.length === 0) return;

      const total = items.reduce((s, i) => s + i.qty * i.price, 0);

      let msg = 'Hola! Quiero hacer un pedido:\n\n';
      items.forEach(i => {
        msg += `- ${i.productName} (${i.variantLabel}) x${i.qty} - $${(i.price * i.qty).toLocaleString('es-CO')}\n`;
      });
      msg += `\n*Total: $${total.toLocaleString('es-CO')}*`;

      window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank');
    });
  }
</script>
