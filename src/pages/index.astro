---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MenuCard from '../components/MenuCard.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const destacados = [
  { name: 'Espresso Doble', description: 'Shot doble de nuestro blend con notas de panela y chocolate.', price: '$5.500' },
  { name: 'V60 de Origen', description: 'Pour over con café de fincas del eje cafetero. Rotación semanal.', price: '$8.000' },
  { name: 'Tostada de Aguacate', description: 'Pan artesanal, aguacate Hass, tomate cherry, semillas y limón.', price: '$14.000' },
  { name: 'Cold Brew Tónica', description: 'Cold brew con agua tónica, hielo y un twist de naranja.', price: '$11.000' },
  { name: 'Flat White', description: 'Doble espresso con microespuma sedosa de leche.', price: '$7.500' },
  { name: 'Brownie', description: 'Chocolate belga, textura húmeda. Servido tibio.', price: '$7.500' },
];

const stats = [
  { number: '100%', label: 'Café colombiano' },
  { number: '8+', label: 'Fincas aliadas' },
  { number: '2019', label: 'Desde' },
];
---

<Layout title="Inicio">
  <Hero
    title="Café de origen en el corazón de Pereira"
    subtitle="Tostamos semanalmente granos de fincas del eje cafetero. Cada taza es trazable, fresca y única."
    ctaText="Ver nuestra carta"
    ctaHref={`${base}menu`}
  />

  <!-- Stats bar -->
  <section class="stats-bar">
    <div class="container stats-inner">
      {stats.map((stat) => (
        <div class="stat">
          <span class="stat-number">{stat.number}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Bento Values -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Lo que nos define</span>
        <h2 class="section-title">Café con propósito</h2>
        <p class="section-subtitle">Cada taza es un vínculo directo con los caficultores de Risaralda.</p>
      </div>
      <div class="bento-grid">
        <div class="bento-card bento-lg">
          <div class="bento-icon">&#9752;</div>
          <h3>Origen Directo</h3>
          <p>Trabajamos con fincas de Risaralda, Quindío y Caldas. Compramos a precio justo y trazamos cada lote desde la finca hasta tu taza.</p>
          <div class="bento-tag">Trazabilidad total</div>
        </div>
        <div class="bento-card">
          <div class="bento-icon">&#9878;</div>
          <h3>Tostión Semanal</h3>
          <p>Tostamos en pequeños lotes cada semana para resaltar los perfiles únicos de cada café.</p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">&#9889;</div>
          <h3>Espacio para Crear</h3>
          <p>WiFi rápido, enchufes, buena música y el ambiente perfecto para trabajar o desconectar.</p>
        </div>
        <div class="bento-card bento-accent">
          <div class="bento-quote">"El mejor café empieza en la finca"</div>
          <div class="bento-attr">Eje Cafetero, Colombia</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Destacados -->
  <section class="section section-featured">
    <div class="container">
      <span class="section-label">Favoritos de la casa</span>
      <h2 class="section-title">Destacados</h2>
      <p class="section-subtitle">Lo más pedido por quienes nos visitan cada día.</p>
      <div class="featured-grid">
        {destacados.map((item) => (
          <MenuCard {...item} />
        ))}
      </div>
      <div class="featured-cta">
        <a href={`${base}menu`} class="btn btn-outline">Ver carta completa &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-bg">
      <div class="cta-orb"></div>
    </div>
    <div class="container cta-inner">
      <span class="section-label" style="color: var(--color-accent);">Te esperamos</span>
      <h2>Ven a conocernos</h2>
      <p>Centro de Pereira. Pasa por un café, quédate a trabajar o disfruta el momento.</p>
      <div class="cta-actions">
        <a href={`${base}contacto`} class="btn btn-primary">Cómo llegar &rarr;</a>
        <a href={`${base}menu`} class="btn btn-ghost">Ver carta</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Stats */
  .stats-bar {
    background: var(--color-bg-warm);
    border-bottom: 1px solid var(--color-border);
    padding: 2.5rem 0;
  }

  .stats-inner {
    display: flex;
    justify-content: center;
    gap: 5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: 1rem;
  }

  /* Bento Grid */
  .bento-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }

  .bento-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
  }

  .bento-card:hover {
    border-color: rgba(212, 160, 90, 0.2);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .bento-lg {
    grid-row: 1 / 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .bento-accent {
    background: var(--color-primary);
    border-color: transparent;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .bento-accent:hover {
    border-color: transparent;
    box-shadow: var(--shadow-lg);
  }

  .bento-icon {
    font-size: 2rem;
    margin-bottom: 1.25rem;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-light);
    border-radius: 16px;
  }

  .bento-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .bento-card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .bento-tag {
    display: inline-flex;
    margin-top: 1.5rem;
    padding: 0.4rem 1rem;
    background: var(--color-accent-light);
    color: var(--color-secondary);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 100px;
    letter-spacing: 0.02em;
  }

  .bento-quote {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.3;
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .bento-attr {
    font-size: 0.8rem;
    color: rgba(254, 254, 254, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
  }

  /* Featured */
  .section-featured {
    background: var(--color-bg-warm);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .featured-cta {
    text-align: center;
    margin-top: 3rem;
  }

  /* CTA */
  .cta-section {
    position: relative;
    background: var(--color-primary);
    padding: 7rem 0;
    overflow: hidden;
    text-align: center;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .cta-orb {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212, 160, 90, 0.15), transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    filter: blur(60px);
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 550px;
  }

  .cta-inner .section-label::before {
    background: var(--color-accent);
  }

  .cta-inner h2 {
    font-size: 3rem;
    color: #fefefe;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .cta-inner p {
    color: rgba(254, 254, 254, 0.45);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-ghost {
    background: transparent;
    color: rgba(254, 254, 254, 0.6);
    border: 1px solid rgba(254, 254, 254, 0.12);
    padding: 1rem 2rem;
    border-radius: 100px;
    font-weight: 500;
    font-size: 0.88rem;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all var(--transition);
  }

  .btn-ghost:hover {
    color: #fefefe;
    border-color: rgba(254, 254, 254, 0.3);
    background: rgba(254, 254, 254, 0.05);
  }

  @media (max-width: 768px) {
    .stats-inner {
      gap: 2.5rem;
    }

    .stat-number {
      font-size: 1.5rem;
    }

    .bento-grid {
      grid-template-columns: 1fr;
    }

    .bento-lg {
      grid-row: auto;
    }

    .bento-card {
      padding: 2rem;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }

    .cta-inner h2 {
      font-size: 2.25rem;
    }
  }
</style>
