---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MenuCard from '../components/MenuCard.astro';

const menu = {
  'Espresso & Clásicos': [
    { name: 'Espresso', description: 'Shot simple de nuestro blend de la casa.', price: '$3.500' },
    { name: 'Espresso Doble', description: 'Doble shot con notas de panela y chocolate.', price: '$5.500' },
    { name: 'Americano', description: 'Espresso con agua caliente, sabor limpio e intenso.', price: '$5.000' },
    { name: 'Café con Leche', description: 'Espresso con leche vaporizada, servido en taza grande.', price: '$6.500' },
    { name: 'Cappuccino', description: 'Espresso, leche vaporizada y espuma cremosa.', price: '$7.000' },
    { name: 'Latte', description: 'Espresso suave con abundante leche vaporizada.', price: '$7.000' },
    { name: 'Flat White', description: 'Doble espresso con microespuma de leche.', price: '$7.500' },
    { name: 'Mocaccino', description: 'Espresso, chocolate artesanal y leche vaporizada.', price: '$8.000' },
  ],
  'Métodos Filtrados': [
    { name: 'V60', description: 'Pour over de café de origen único. Rotación semanal de finca.', price: '$8.000' },
    { name: 'Chemex', description: 'Filtrado limpio y brillante, ideal para cafés florales.', price: '$9.000' },
    { name: 'Aeropress', description: 'Cuerpo medio, dulzura concentrada. Nuestro método favorito.', price: '$8.000' },
    { name: 'Cold Brew', description: 'Extracción en frío por 18 horas. Suave y refrescante.', price: '$9.000' },
    { name: 'Cold Brew Tónica', description: 'Cold brew con agua tónica, hielo y un twist de naranja.', price: '$11.000' },
  ],
  'Té & Otras Bebidas': [
    { name: 'Té Negro / Verde', description: 'Selección de hojas sueltas, servido en tetera.', price: '$5.000' },
    { name: 'Chai Latte', description: 'Té negro especiado con leche vaporizada y canela.', price: '$7.500' },
    { name: 'Matcha Latte', description: 'Matcha ceremonial con leche de tu elección.', price: '$9.000' },
    { name: 'Chocolate Caliente', description: 'Chocolate artesanal de cacao colombiano con leche.', price: '$7.000' },
    { name: 'Limonada de Panela', description: 'Limonada natural endulzada con panela orgánica.', price: '$6.000' },
    { name: 'Jugo Natural', description: 'Naranja, maracuyá o lulo. Preparado al momento.', price: '$6.500' },
  ],
  'Panadería & Dulces': [
    { name: 'Pan de Bono (x3)', description: 'Recién horneados, crujientes y con queso del Quindío.', price: '$4.500' },
    { name: 'Buñuelos (x3)', description: 'Buñuelos de queso esponjosos, receta tradicional.', price: '$4.500' },
    { name: 'Almojábana (x2)', description: 'Masa de maíz con queso, textura suave y dorada.', price: '$4.000' },
    { name: 'Torta de Banano', description: 'Con nueces y banano del Valle, glaseado de limón.', price: '$7.000' },
    { name: 'Brownie', description: 'Chocolate belga, textura húmeda. Servido tibio.', price: '$7.500' },
    { name: 'Cheesecake del Día', description: 'Pregunta por el sabor de hoy.', price: '$8.000' },
  ],
  'Comida': [
    { name: 'Tostada de Aguacate', description: 'Pan artesanal, aguacate Hass, tomate cherry, semillas y limón.', price: '$14.000' },
    { name: 'Sándwich de Pollo', description: 'Pan ciabatta, pollo desmechado, pesto y rúcula.', price: '$16.000' },
    { name: 'Wrap Veggie', description: 'Tortilla integral con hummus, vegetales grillados y hojas verdes.', price: '$14.000' },
    { name: 'Croissant de Jamón', description: 'Croissant de mantequilla, jamón serrano, queso y rúcula.', price: '$13.000' },
    { name: 'Bowl de Granola', description: 'Granola artesanal, yogurt griego, frutas frescas y miel.', price: '$12.000' },
    { name: 'Huevos del Campo', description: 'Huevos al gusto con pan artesanal y ensalada.', price: '$13.000' },
  ],
  'Brunch — Sábados y Domingos': [
    { name: 'Brunch Clásico', description: 'Bebida caliente, jugo natural, pan de bono, huevos y fruta.', price: '$22.000' },
    { name: 'Brunch Independencia', description: 'Todo lo del clásico más pancakes, sándwich y una copa de mimosa.', price: '$32.000' },
  ],
};

const categories = Object.entries(menu);
---

<Layout title="Carta" description="Nuestra carta de café de especialidad, métodos filtrados, panadería artesanal y comida fresca en Pereira.">
  <Hero
    title="Nuestra Carta"
    subtitle="Ingredientes locales, preparación artesanal"
    compact
  />

  <!-- Category nav -->
  <div class="menu-nav-wrapper">
    <div class="container">
      <nav class="menu-nav">
        {categories.map(([category], i) => (
          <a href={`#cat-${i}`} class="menu-nav-item">{category}</a>
        ))}
      </nav>
    </div>
  </div>

  <div class="menu-page">
    {categories.map(([category, items], i) => (
      <section class:list={['menu-section', { alt: i % 2 !== 0 }]} id={`cat-${i}`}>
        <div class="container">
          <div class="menu-section-header">
            <span class="section-label">{String(i + 1).padStart(2, '0')}</span>
            <h2>{category}</h2>
          </div>
          <div class="menu-grid">
            {items.map((item) => (
              <MenuCard {...item} />
            ))}
          </div>
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
  .menu-nav-wrapper {
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 5rem;
    z-index: 50;
  }

  .menu-nav {
    display: flex;
    gap: 0.5rem;
    padding: 1rem 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .menu-nav::-webkit-scrollbar {
    display: none;
  }

  .menu-nav-item {
    white-space: nowrap;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text-light);
    background: var(--color-bg-warm);
    border: 1px solid var(--color-border);
    transition: all var(--transition-fast);
  }

  .menu-nav-item:hover {
    color: var(--color-primary);
    background: var(--color-accent-light);
    border-color: rgba(212, 160, 90, 0.2);
  }

  .menu-page {
    padding-bottom: 2rem;
  }

  .menu-section {
    padding: 4.5rem 0 3.5rem;
    scroll-margin-top: 8rem;
  }

  .menu-section.alt {
    background: var(--color-bg-warm);
  }

  .menu-section-header {
    margin-bottom: 2.5rem;
  }

  .menu-section-header h2 {
    font-size: 2.25rem;
    letter-spacing: -0.03em;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .menu-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .menu-nav-wrapper {
      top: 4.5rem;
    }

    .menu-grid {
      grid-template-columns: 1fr;
    }

    .menu-section-header h2 {
      font-size: 1.75rem;
    }
  }
</style>
