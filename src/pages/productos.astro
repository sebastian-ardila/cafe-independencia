---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const products = [
  {
    id: 'media-libra',
    name: 'Media Libra de Café',
    weight: '250g',
    description: 'Café de origen del eje cafetero, tostado artesanal semanal. Perfil con notas de panela, chocolate y frutas.',
    price: 25000,
    icon: '&#9749;',
  },
  {
    id: 'libra',
    name: 'Libra de Café',
    weight: '500g',
    description: 'Nuestro café insignia en presentación completa. Ideal para el hogar o la oficina. Molido o en grano.',
    price: 45000,
    icon: '&#9749;&#9749;',
    popular: true,
  },
  {
    id: 'cold-brew',
    name: 'Cold Brew',
    weight: '350ml',
    description: 'Extracción en frío por 18 horas. Listo para tomar. Suave, dulce y refrescante. Botella de vidrio.',
    price: 12000,
    icon: '&#129380;',
  },
];

const formatPrice = (price: number) => {
  return '$' + price.toLocaleString('es-CO');
};
---

<Layout title="Productos" description="Pide nuestro café de especialidad directo de Pereira. Media libra, libra y Cold Brew listos para ti.">
  <Hero
    title="Nuestros Productos"
    subtitle="Café de origen tostado artesanalmente cada semana. Directo del eje cafetero a tu casa."
    compact
  />

  <section class="section products-section">
    <div class="container">
      <div class="products-grid">
        {products.map((product) => (
          <div class="product-card" data-product-id={product.id} data-product-name={product.name} data-product-price={product.price}>
            {product.popular && <div class="popular-badge">Más vendido</div>}
            <div class="product-icon" set:html={product.icon} />
            <div class="product-info">
              <h3>{product.name}</h3>
              <span class="product-weight">{product.weight}</span>
              <p>{product.description}</p>
            </div>
            <div class="product-bottom">
              <div class="product-price">{formatPrice(product.price)}</div>
              <div class="quantity-control">
                <button class="qty-btn qty-minus" aria-label="Reducir cantidad">−</button>
                <span class="qty-value">0</span>
                <button class="qty-btn qty-plus" aria-label="Aumentar cantidad">+</button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Floating Cart -->
  <div class="cart-float" id="cart-float">
    <div class="cart-summary">
      <div class="cart-info">
        <div class="cart-icon-wrap">
          <svg class="cart-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <span class="cart-badge" id="cart-badge">0</span>
        </div>
        <div class="cart-details">
          <span class="cart-items-text" id="cart-items-text">Tu pedido</span>
          <span class="cart-total" id="cart-total">$0</span>
        </div>
      </div>
      <button class="btn btn-whatsapp cart-checkout" id="cart-checkout">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir por WhatsApp
      </button>
    </div>
    <div class="cart-items-list" id="cart-items-list"></div>
  </div>
</Layout>

<style>
  .products-section {
    padding-top: 4rem;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1050px;
    margin: 0 auto;
  }

  /* Product Card */
  .product-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: all var(--transition);
    overflow: hidden;
  }

  .product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-secondary), var(--color-accent));
    opacity: 0;
    transition: opacity var(--transition);
  }

  .product-card:hover {
    border-color: rgba(200, 150, 90, 0.15);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .product-card:hover::before {
    opacity: 1;
  }

  .product-card.selected {
    border-color: var(--color-secondary);
    box-shadow: var(--shadow-glow);
  }

  .product-card.selected::before {
    opacity: 1;
  }

  .popular-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: linear-gradient(135deg, var(--color-secondary), var(--color-accent));
    color: var(--color-white);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
  }

  .product-icon {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-light);
    border-radius: 18px;
    line-height: 1;
  }

  .product-info {
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .product-info h3 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    letter-spacing: -0.02em;
  }

  .product-weight {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-secondary);
    background: var(--color-accent-light);
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.85rem;
  }

  .product-info p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.65;
  }

  .product-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .product-price {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    letter-spacing: -0.02em;
  }

  /* Quantity Control */
  .quantity-control {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--color-bg);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .qty-btn {
    width: 38px;
    height: 38px;
    border: none;
    background: transparent;
    cursor: pointer;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-light);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
    font-family: var(--font-body);
  }

  .qty-btn:hover {
    background: var(--color-accent-light);
    color: var(--color-secondary);
  }

  .qty-btn:active {
    transform: scale(0.92);
  }

  .qty-value {
    min-width: 32px;
    text-align: center;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  /* Floating Cart */
  .cart-float {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(120%);
    z-index: 90;
    width: calc(100% - 3rem);
    max-width: 560px;
    background: var(--color-primary);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl), 0 0 0 1px rgba(255, 255, 255, 0.05);
    padding: 1.25rem 1.5rem;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    backdrop-filter: blur(20px);
  }

  .cart-float.visible {
    transform: translateX(-50%) translateY(0);
  }

  .cart-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cart-info {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .cart-icon-wrap {
    position: relative;
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    color: var(--color-white);
  }

  .cart-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 20px;
    height: 20px;
    background: var(--color-whatsapp);
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--transition-bounce);
  }

  .cart-badge.bump {
    animation: pulse 0.3s ease;
  }

  .cart-details {
    display: flex;
    flex-direction: column;
  }

  .cart-items-text {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 500;
  }

  .cart-total {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-white);
  }

  .cart-checkout {
    padding: 0.75rem 1.5rem;
    font-size: 0.85rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .cart-items-list {
    display: none;
    padding-top: 1rem;
    margin-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    flex-direction: column;
    gap: 0.5rem;
  }

  .cart-items-list.show {
    display: flex;
  }

  :global(.cart-item-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
  }

  :global(.cart-item-qty) {
    color: var(--color-accent);
    font-weight: 600;
  }

  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .products-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }

    .product-card {
      padding: 2rem 1.5rem 1.5rem;
    }

    .cart-float {
      bottom: 1rem;
      width: calc(100% - 2rem);
      padding: 1rem 1.25rem;
      border-radius: var(--radius-lg);
    }

    .cart-summary {
      flex-wrap: wrap;
    }

    .cart-checkout {
      width: 100%;
      margin-top: 0.5rem;
    }
  }
</style>

<script define:vars={{ }}>
  const WHATSAPP_NUMBER = '573023231629';
  const cart = {};

  function updateUI() {
    const totalItems = Object.values(cart).reduce((sum, item) => sum + item.qty, 0);
    const totalPrice = Object.values(cart).reduce((sum, item) => sum + item.qty * item.price, 0);

    // Badge
    const badge = document.getElementById('cart-badge');
    if (badge) {
      badge.textContent = String(totalItems);
      badge.classList.remove('bump');
      void badge.offsetWidth;
      badge.classList.add('bump');
    }

    // Total
    const totalEl = document.getElementById('cart-total');
    if (totalEl) totalEl.textContent = '$' + totalPrice.toLocaleString('es-CO');

    // Items text
    const itemsText = document.getElementById('cart-items-text');
    if (itemsText) {
      itemsText.textContent = totalItems === 0 ? 'Tu pedido' :
        totalItems === 1 ? '1 producto' : totalItems + ' productos';
    }

    // Floating cart visibility
    const cartFloat = document.getElementById('cart-float');
    if (cartFloat) {
      cartFloat.classList.toggle('visible', totalItems > 0);
    }

    // Items list
    const listEl = document.getElementById('cart-items-list');
    if (listEl) {
      listEl.innerHTML = '';
      listEl.classList.toggle('show', totalItems > 0);
      for (const [id, item] of Object.entries(cart)) {
        if (item.qty > 0) {
          const row = document.createElement('div');
          row.className = 'cart-item-row';
          row.innerHTML = `<span>${item.name}</span><span class="cart-item-qty">${item.qty}x $${(item.price * item.qty).toLocaleString('es-CO')}</span>`;
          listEl.appendChild(row);
        }
      }
    }

    // Card selected state
    document.querySelectorAll('.product-card').forEach(card => {
      const id = card.getAttribute('data-product-id');
      if (id && cart[id]) {
        card.classList.toggle('selected', cart[id].qty > 0);
      }
    });
  }

  document.querySelectorAll('.product-card').forEach(card => {
    const id = card.getAttribute('data-product-id');
    const name = card.getAttribute('data-product-name');
    const price = parseInt(card.getAttribute('data-product-price') || '0');
    const qtyEl = card.querySelector('.qty-value');
    const minusBtn = card.querySelector('.qty-minus');
    const plusBtn = card.querySelector('.qty-plus');

    if (!id || !qtyEl || !minusBtn || !plusBtn) return;

    cart[id] = { name, price, qty: 0 };

    plusBtn.addEventListener('click', () => {
      cart[id].qty++;
      qtyEl.textContent = String(cart[id].qty);
      updateUI();
    });

    minusBtn.addEventListener('click', () => {
      if (cart[id].qty > 0) {
        cart[id].qty--;
        qtyEl.textContent = String(cart[id].qty);
        updateUI();
      }
    });
  });

  // Checkout WhatsApp
  const checkoutBtn = document.getElementById('cart-checkout');
  if (checkoutBtn) {
    checkoutBtn.addEventListener('click', () => {
      const items = Object.values(cart).filter(item => item.qty > 0);
      if (items.length === 0) return;

      const total = items.reduce((sum, item) => sum + item.qty * item.price, 0);

      let message = '¡Hola! Quiero hacer un pedido:\n\n';
      items.forEach(item => {
        message += `• ${item.name} x${item.qty} — $${(item.price * item.qty).toLocaleString('es-CO')}\n`;
      });
      message += `\n*Total: $${total.toLocaleString('es-CO')}*`;
      message += '\n\n¡Gracias!';

      const encoded = encodeURIComponent(message);
      window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encoded}`, '_blank');
    });
  }
</script>
